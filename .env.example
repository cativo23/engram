# Copy this file to `.env` and fill it in. The .env file is gitignored.
# Get a free key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Optional: which model to use. Any id from https://openrouter.ai/models.
# Defaults to openai/gpt-oss-120b:free if unset.
MODEL=openai/gpt-oss-120b:free
